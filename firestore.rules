rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, displayName, photoURL, role, createdAt, updatedAt
    //
    // Collection: products
    // Fields: name, description, price, category, images, stock, rating, reviewsCount, createdAt, updatedAt
    //
    // Collection: categories
    // Fields: name, icon, slug
    //
    // Collection: orders
    // Fields: userId, items, total, status, paymentId, paymentStatus, shippingAddress, createdAt
    //
    // Collection: reviews
    // Fields: productId, userId, userName, rating, comment, createdAt
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "vaishnavijojare440@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'customer'];
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'category', 'stock']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.price is number && data.price >= 0 &&
             data.category is string &&
             data.stock is int && data.stock >= 0;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'total', 'status']) &&
             data.userId == request.auth.uid &&
             data.total is number && data.total >= 0 &&
             data.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled'];
    }

    function isValidCoupon(data) {
      return data.keys().hasAll(['code', 'type', 'value', 'expiryDate', 'isActive']) &&
             data.code is string && data.code.size() > 0 &&
             data.type in ['percentage', 'fixed'] &&
             data.value is number && data.value > 0 &&
             data.expiryDate is string &&
             data.isActive is bool;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) && request.resource.data.role == 'customer' || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) && request.resource.data.role == resource.data.role || isAdmin());
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() && isValidProduct(request.resource.data);
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated() && isValidOrder(request.resource.data);
      allow update: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    match /coupons/{couponId} {
      allow read: if isAuthenticated();
      allow create, delete: if isAdmin() && isValidCoupon(request.resource.data);
      allow update: if isAdmin() && isValidCoupon(request.resource.data) || 
                    (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usageCount']) && 
                     request.resource.data.usageCount == resource.data.usageCount + 1);
    }
  }
}
